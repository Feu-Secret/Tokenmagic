<section class="flexcol" style="gap: 5px;">

    <div class="form-group">    
        <label>{{localize "DOCUMENT.FIELDS.name.label"}}</label>
        <div class="form-fields">
            <input type="text" name="name" value="{{name}}"/>
        </div>
    </div>

    <div class="form-group">    
        <label>{{localize "TMFX.app.editPreset.option.library"}}</label>
        <div class="form-fields">
            <input type="text" value="{{library}}" disabled/>
        </div>
    </div>

    {{#if defaultTexture}}
    <div class="form-group">    
        <label>{{localize "TMFX.app.editPreset.option.defaultTexture"}}</label>
        <div class="form-fields">
            <file-picker name="defaultTexture" type="imagevideo" value="{{defaultTexture}}"></file-picker>
        </div>
    </div>
    {{/if}}

    <label>Params:</label>
    <textarea style="width: 100%; height: 280px;" readonly>{{params}}</textarea>
</section>